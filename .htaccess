# visience.ro — site static (Next.js export)

Options -Indexes
AddDefaultCharset UTF-8
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
RewriteEngine On

# un singur hop: http / www -> https://visience.ro
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://visience.ro/$1 [R=301,L]

# fisierele existente (inclusiv wp-content/uploads) se servesc direct
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# sitemap-urile vechi Yoast -> sitemap-ul nou
RewriteRule ^sitemap_index\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^(post|page|category)-sitemap\.xml$ /sitemap.xml [R=301,L]

# URL-urile vechi WordPress -> paginile noi (301)
RewriteRule ^creare-sitede-prezentare/?$ /creare-site-prezentare/ [R=301,L]
RewriteRule ^ppc-google-meta-ads/?$ /google-meta-ads/ [R=301,L]
RewriteRule ^seo-content-marketing/?$ /optimizare-seo/ [R=301,L]
RewriteRule ^software-app-development/?$ /dezvoltare-software/ [R=301,L]
RewriteRule ^pagina-multumire/?$ /multumire/ [R=301,L]
RewriteRule ^category/articole/?$ /blog/ [R=301,L]
RewriteRule ^category/articole/.+$ /blog/ [R=301,L]
